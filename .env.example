# moemail API 配置
MOEMAIL_API_URL=https://api.moemail.app
MOEMAIL_API_KEY=your-moemail-api-key
# moemail 请求代理（可选，不填则复用 GROK_PROXY_URL）
MOEMAIL_PROXY_URL=
# moemail HTTPS 证书校验（可选：true/false，默认无代理时开启，有代理时关闭）
MOEMAIL_VERIFY_SSL=

# Turnstile 验证配置
# 如果不填则使用本地 Turnstile Solver（http://127.0.0.1:5072）
YESCAPTCHA_KEY=
# Solver 结果存储后端（memory/sqlite，默认 memory）
SOLVER_RESULT_STORE=memory
# 当 SOLVER_RESULT_STORE=sqlite 时使用的数据库路径
SOLVER_RESULT_DB_PATH=logs/solver/solver-results.sqlite3

# Grok 主流程 HTTP 代理（可选）
GROK_PROXY_URL=

# 注册成功后是否保留邮箱（true/false，默认 false）
KEEP_SUCCESS_EMAIL=false

# 是否在注册后自动开启 NSFW/Unhinged（true/false，默认 true）
ENABLE_NSFW=true

# NSFW 后置请求超时秒数（可选，默认 20）
NSFW_TIMEOUT=20
# NSFW 后置请求重试次数（可选，默认 2）
NSFW_RETRY_ATTEMPTS=2
# NSFW 后置请求并发闸门（可选，默认 3）
NSFW_CONCURRENT=3
# Unhinged feature key（可选，不填使用内置候选）
UNHINGED_FEATURE_KEY=
